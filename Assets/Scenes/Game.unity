  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Moi, je suis la tulipe, une fleur de Hollande\_;\nEt telle est ma beaut\xE9,
    que l\u2019avare Flamand\nPaye un de mes                plus cher qu\u2019un                 
    ,\nSi mes fonds sont bien purs, si je suis droite et grande.\n\nMon air est f\xE9odal,
    et, comme une Yolande\nDans sa          \xE0 longs plis \xE9toff\xE9e amplement,\LJe
    porte des blasons peints sur mon v\xEAtement,\LGueules fasc\xE9 d\u2019argent,
    or avec pourpre en bande.\L\LLe jardinier divin a fil\xE9 de ses doigts\LLes
    rayons du soleil et la pourpre des rois\LPour me faire une          \xE0 trame
    douce et fine.\L\LNulle fleur du jardin n\u2019\xE9gale ma splendeur,\LMais la
    nature, h\xE9las\_! n\u2019a pas vers\xE9 d\u2019odeur\LDans mon             
    fait comme un vase de Chine."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
